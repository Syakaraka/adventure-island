<?xml version="1.0" encoding="utf-8"?>
<!-- 冒险岛游戏图标 - 带圆角和渐变效果 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 白色圆角背景 -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    
    <!-- 主图标区域 -->
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <layer-list>
            <!-- 蓝天背景 -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#87CEEB" />
                    <corners android:radius="24dp" />
                </shape>
            </item>
            
            <!-- 绿色草地 (底部 25% = 24dp) -->
            <item android:bottom="0dp" android:height="24dp">
                <shape android:shape="rectangle">
                    <solid android:color="#228B22" />
                    <corners android:bottomLeftRadius="24dp" android:bottomRightRadius="24dp" />
                </shape>
            </item>
            
            <!-- 黄色太阳 -->
            <item android:top="8dp" android:right="8dp">
                <shape android:shape="oval">
                    <solid android:color="#FFD700" />
                    <size android:width="20dp" android:height="20dp" />
                </shape>
            </item>
            
            <!-- 简单的小人角色 (底部 15% = 14dp) -->
            <item android:bottom="14dp" android:gravity="center_horizontal">
                <layer-list>
                    <!-- 身体 -->
                    <item android:width="16dp" android:height="20dp" android:gravity="center">
                        <shape android:shape="rectangle">
                            <solid android:color="#FF6347" />
                            <corners android:radius="4dp" />
                        </shape>
                    </item>
                    <!-- 头部 -->
                    <item android:top="4dp" android:width="12dp" android:height="12dp" android:gravity="center_horizontal|top">
                        <shape android:shape="oval">
                            <solid android:color="#FFDAB9" />
                        </shape>
                    </item>
                </layer-list>
            </item>
        </layer-list>
    </item>
</layer-list>
